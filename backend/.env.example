# Copy to `.env` for local backend. Never commit `.env`.

# --- Supabase (preferred for portfolios / marketplace DB) ---
# Project URL from Supabase → Settings → API
SUPABASE_URL=

# Prefer service role on the server (bypasses RLS). Keep secret; do not expose to Vercel frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Optional fallback for local/testing only — anon/public key is weaker; production backend should use service role.
SUPABASE_ANON_KEY=

# --- MongoDB (used only if Supabase URL + key are not set) ---
MONGO_URL=mongodb://localhost:27017
DB_NAME=homemaker

# --- Optional: AI routes on backend ---
HM_AI_IMAGE_API_KEY=
HM_AI_PLAN_API_KEY=
