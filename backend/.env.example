# Copy to `.env` for local backend. Never commit `.env`.

# --- Supabase (preferred for portfolios / marketplace DB) ---
# Project URL from Supabase → Settings → API
SUPABASE_URL=

# Prefer service role on the server (bypasses RLS). Keep secret; do not expose to Vercel frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Optional fallback for local/testing only — anon/public key is weaker; production backend should use service role.
SUPABASE_ANON_KEY=

# --- Razorpay (India checkout) ---
# Start with Test Mode keys. Switch to Live Mode only after the test checklist passes.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# A separate secret you choose when adding https://YOUR_API/api/billing/webhook
# in Razorpay Dashboard. Subscribe to order.paid, payment.captured, payment.failed.
RAZORPAY_WEBHOOK_SECRET=
# Checkout is fail-closed even when keys are present. Keep both false until paid
# benefits are enforced, refunds/expiry are tested, and live billing is approved.
BILLING_ENABLED=false
ALLOW_LIVE_BILLING=false

# --- MongoDB (used only if Supabase URL + key are not set) ---
MONGO_URL=mongodb://localhost:27017
DB_NAME=homemaker
MONGO_SERVER_SELECTION_TIMEOUT_MS=3000
ALLOW_MONGO_FALLBACK=false

# --- Browser and native app origins ---
# Capacitor uses https://localhost on Android and capacitor://localhost on iOS.
CORS_ORIGINS=https://www.homemakers.online,https://homemakers.online,https://localhost,capacitor://localhost,http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGIN_REGEX=https://(homemakers(-1|final)?|frontend)(-[a-z0-9-]+)?\.vercel\.app

# --- Request and provider-spend safeguards ---
# Keep provider fallbacks disabled outside explicit local demos.
ALLOW_AI_MOCKS=false
AI_RATE_LIMIT_REQUESTS=12
AI_RATE_LIMIT_WINDOW_SECONDS=60
AI_MAX_CONCURRENT_REQUESTS=4
AI_MAX_CONCURRENT_PER_USER=2
AI_CAPACITY_RETRY_SECONDS=2
AI_DAILY_IMAGE_PACKS=3
HUB_CONTEXT_MAX_BYTES=65536
AI_BRIEF_MAX_BYTES=2097152
AI_IMAGE_BUNDLE_MAX_BYTES=524288
RAZORPAY_WEBHOOK_MAX_BYTES=262144
MAX_REQUEST_BODY_BYTES=5242880

# --- xAI Grok (design images + estimates) — https://console.x.ai ---
# One key can power both routes; $5 prepaid ≈ ~250 images @ $0.02 or many estimate calls.
XAI_API_KEY=

# Optional overrides (same xAI key is fine for both):
HM_AI_IMAGE_API_KEY=
HM_AI_PLAN_API_KEY=

# Image model: grok-imagine-image ($0.02/img). Use grok-imagine-image-quality only if you need higher fidelity ($0.05).
GROK_IMAGE_MODEL=grok-imagine-image
# Chat model for estimate JSON (grok-3-mini is cost-efficient on xAI).
GROK_CHAT_MODEL=grok-3-mini
# Return generated image bytes so the frontend can save them durably in private Supabase Storage.
GROK_INLINE_IMAGES=1
# New build: 1 front holistic elevation + Grok floor plans.
GROK_V0_NEW_HOME_IMAGES=1
GROK_V0_FLOOR_PLANS=1
# Remodel: up to 2 sequential interior angles; no floor plans by default.
GROK_V0_REMODEL_IMAGES=2
GROK_V0_REMODEL_FLOOR_PLANS=0
GROK_V0_MAX_FLOOR_PLANS=1
