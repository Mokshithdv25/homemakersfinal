# Copy to `.env` for local `npm start`. Never commit `.env`.
# CRA only reads vars prefixed with REACT_APP_.

# Backend API origin (no trailing slash). Example: https://your-api.up.railway.app
# If unset, requests default to same-origin `/api` (needs a rewrite/proxy if you rely on it).
# Local: http://localhost:8000 (or omit — dev proxy in package.json forwards /api → :8000)
REACT_APP_BACKEND_URL=http://localhost:8000

# Canonical public site used for profile links shared from iOS/Android.
REACT_APP_PUBLIC_WEB_URL=https://www.homemakers.online
# Exact legal name on your GST / Udyam / company registration (Razorpay website review).
REACT_APP_LEGAL_BUSINESS_NAME=GOOD LIFE INNOVATION VENTURES
REACT_APP_UDYAM_REGISTRATION=UDYAM-KR-16-0073899
REACT_APP_LEGAL_BUSINESS_ADDRESS=847 Ruthudhama, 2nd Cross, Udayagiri extension, Hassan, Karnataka 573201, India
REACT_APP_BILLING_ENABLED=false
# Optional fallback only — checkout key_id is returned by POST /api/billing/order.
# Never put RAZORPAY_KEY_SECRET in the frontend.
# REACT_APP_RAZORPAY_KEY_ID=
# Keep false until Supabase custom SMTP is configured and end-to-end delivery is verified.
REACT_APP_EMAIL_SIGNUP_ENABLED=false

# Safe in the browser — anon/publishable key from Supabase → Settings → API (not service_role).
# URL: https://YOUR_REF.supabase.co
# Key: eyJ... (legacy anon JWT) OR sb_publishable_... (new publishable key) — both work.
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=
