# Copy to `.env` for local `npm start`. Never commit `.env`.
# CRA only reads vars prefixed with REACT_APP_.

# Backend API origin (no trailing slash). Example: https://your-api.up.railway.app
# If unset, requests default to same-origin `/api` (needs a rewrite/proxy if you rely on it).
# Local: http://localhost:8000 (or omit — dev proxy in package.json forwards /api → :8000)
REACT_APP_BACKEND_URL=http://localhost:8000

# Safe in the browser — anon/publishable key from Supabase → Settings → API (not service_role).
# URL: https://YOUR_REF.supabase.co
# Key: eyJ... (legacy anon JWT) OR sb_publishable_... (new publishable key) — both work.
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=
